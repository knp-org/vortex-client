{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vortex-client",
  "version": "0.2.4",
  "identifier": "org.knp.vortex-client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vortex Client",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "mpv",
          "libwebkit2gtk-4.0-37",
          "libgtk-3-0"
        ]
      }
    }
  }
}
